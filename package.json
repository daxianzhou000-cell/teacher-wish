{
  "name": "makeup-lesson-kit-generator",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:reset": "rm -rf .next-dev && next dev",
    "build": "next build",
    "build:clean": "rm -rf .next && next build",
    "start": "next start",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck.json",
    "clean": "rm -rf .next .next-dev",
    "clean:dev": "rm -rf .next-dev",
    "clean:build": "rm -rf .next",
    "verify": "npm run build && npm run typecheck"
  },
  "dependencies": {
    "katex": "^0.16.45",
    "next": "14.2.30",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@types/node": "22.14.1",
    "@types/react": "18.3.20",
    "@types/react-dom": "18.3.6",
    "autoprefixer": "10.4.21",
    "postcss": "8.5.3",
    "tailwindcss": "3.4.17",
    "typescript": "5.8.3"
  }
}
